# Force all text files to use LF line endings in the repository
* text=auto

# Explicitly mark Python and config files as UTF-8 text
*.py text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.sql text eol=lf
*.json text eol=lf
Procfile text eol=lf
.env.example text eol=lf

# Binary files — never touch encoding
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.webp binary
*.svg binary
