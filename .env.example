# Database — use your local values locally, Railway fills these automatically on Railway
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Flask
SECRET_KEY=
FLASK_ENV=production
FLASK_DEBUG=0

# Session security — set to True in production
SESSION_COOKIE_SECURE=True

# PayMongo — use sk_test_... / pk_test_... for testing, sk_live_... / pk_live_... for production
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=

# Gmail SMTP — use a Gmail App Password (not your real Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
